# Copy this file to .env.local and fill in real credentials.
# .env.local is gitignored — never commit real credentials.

# PostgreSQL connection string for the comments database.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://tintero:tintero@localhost:5432/tintero

# Secret for signing session JWTs (HS256). Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Optional — static Bearer token for write API (leave empty to disable Bearer auth).
# When set, requests with "Authorization: Bearer <token>" can create/update/delete content.
# Generate with: openssl rand -hex 32
API_TOKEN=

# ---------------------------------------------------------------------------
# Content layer (CONTENT_STORE=db selects the Drizzle adapter)
# ---------------------------------------------------------------------------

# Selects the content storage backend.
# Accepted values: "fs" (filesystem, default) | "db" (Drizzle/SQL adapter)
CONTENT_STORE=fs

# Database dialect for the content layer.
# Accepted values: "postgresql" | "sqlite"
DATABASE_DIALECT=sqlite

# SQLite database file path for the content layer (DATABASE_DIALECT=sqlite).
# The app defaults to ":memory:" when unset; drizzle-kit push requires a real file path.
# Example: /var/lib/tintero/content.db  or  ./content.db
DATABASE_FILE=/path/to/content.db
